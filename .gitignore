# Python
__pycache__/
*.py[co]
*.egg-info/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Virtualenv
.venv/
venv/
.env

# SCons build artifacts
.sconsign.dblite
/[0-9]*.[0-9]*.[0-9]*.json

# Add-on build outputs
*.nvda-addon
*.pot
*.mo

# Generated docs (built by scons from addon/doc/*/readme.md)
*.html

# Generated manifest (built by scons from manifest.ini.tpl).
# Per-locale manifests under addon/locale/*/manifest.ini are source templates,
# so we only ignore the top-level generated one.
/addon/manifest.ini

# Bundled Python dependencies.
# NVDA ships Python 3.11 32-bit, so C extensions must match that ABI.
# Install locally via:
#   uv pip install --python 3.11 --target addon/lib64 --python-platform x86_64-pc-windows-msvc -r addon/requirements.txt
#   uv pip install --python 3.11 --target addon/lib32 --python-platform i686-pc-windows-msvc   -r addon/requirements.txt
# They are intentionally NOT committed because they are large and
# platform-specific.
/addon/lib32/
/addon/lib64/

# IDE / editor
.vscode/
.idea/
*.swp
*~

# macOS / Windows cruft
.DS_Store
Thumbs.db

# Claude Code per-user settings
.claude/settings.local.json
